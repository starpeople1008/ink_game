# 기본 줄바꿈 자동 정규화
* text=auto

# Unity 텍스트 파일 - 머지 툴 지원
*.cs        text diff=csharp
*.meta      text merge=unityyamlmerge
*.unity     text merge=unityyamlmerge diff=unity
*.prefab    text merge=unityyamlmerge diff=unity
*.asset     text merge=unityyamlmerge diff=unity
*.anim      text merge=unityyamlmerge diff=unity
*.controller text merge=unityyamlmerge diff=unity
*.mat       text merge=unityyamlmerge diff=unity
*.shader    text
*.json      text
*.xml       text
*.txt       text
*.md        text

# 바이너리 파일 - 줄바꿈 변환 없음
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.psd       binary
*.tga       binary
*.tif       binary
*.fbx       binary
*.wav       binary
*.mp3       binary
*.ogg       binary
*.dll       binary
*.exe       binary
*.zip       binary
*.unitypackage binary
